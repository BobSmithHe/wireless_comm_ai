# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=wireless_comm_ai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# DeepSeek API
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# JWT
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret

# Langfuse (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=false

# ChromaDB
CHROMA_HOST=
CHROMA_PORT=8000

# Code execution
SANDBOX_MODE=subprocess
CODE_EXEC_TIMEOUT=30

# Context compression
CONTEXT_COMPRESSION_ENABLED=true
CONTEXT_COMPRESSION_BUDGET_TOKENS=4000

# Knowledge base
KB_CHUNK_SIZE=1000
KB_CHUNK_OVERLAP=200
KB_MAX_UPLOAD_SIZE_MB=50
KB_CONTEXT_BUDGET_TOKENS=2000
KB_HYBRID_SEARCH=true
KB_RERANK_ENABLED=true
