# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-password
DB_NAME=wireless_comm_ai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# DeepSeek API
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# JWT
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret

# ZhipuAI (optional, for reranking)
ZHIPU_API_KEY=

# Tavily Web Search (optional)
TAVILY_API_KEY=tvly-dev-...

# Langfuse (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=false

# Milvus
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=milvus_database

# Embedding model
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu

# Code execution
SANDBOX_MODE=subprocess
CODE_EXEC_TIMEOUT=30

# Context compression (message count based)
CONTEXT_COMPRESSION_ENABLED=true
CONTEXT_COMPRESSION_TRIGGER_ROUNDS=10
CONTEXT_COMPRESSION_KEEP_ROUNDS=5
CONTEXT_COMPRESSION_SUMMARY_MAX_TOKENS=500

# Knowledge base
KB_CHUNK_SIZE=1000
KB_CHUNK_OVERLAP=200
KB_MAX_UPLOAD_SIZE_MB=50
KB_CONTEXT_BUDGET_TOKENS=2000
KB_HYBRID_SEARCH=true
KB_RERANK_ENABLED=true
